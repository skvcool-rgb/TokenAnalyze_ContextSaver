{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "python ~/.claude/tools/write_guard.py", "timeout": 10 }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "auto|manual",
        "hooks": [
          { "type": "command", "command": "python ~/.claude/tools/checkpoint.py", "timeout": 40 }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          { "type": "command", "command": "python ~/.claude/tools/resume.py", "timeout": 15 }
        ]
      }
    ]
  }
}
